{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "uid": "ratebridge-trading",
  "title": "RateBridge — Trading",
  "tags": ["ratebridge", "trading"],
  "timezone": "",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "links": [],
  "panels": [
    {
      "title": "Bot",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "ratebridge_bot_up", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "title": "Active Positions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "ratebridge_active_positions", "refId": "A" }],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } } }
    },
    {
      "title": "Total Balance",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "ratebridge_total_balance_usd", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 } }
    },
    {
      "title": "Lifetime PnL",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "ratebridge_total_pnl_usd", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0 } ] }
        }
      }
    },
    {
      "title": "Completed Trades",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "targets": [{ "expr": "ratebridge_trades_completed_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "decimals": 0 } }
    },
    {
      "title": "Win Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "targets": [
        {
          "expr": "ratebridge_trades_winning_total / clamp_min(ratebridge_trades_completed_total, 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1, "min": 0, "max": 1 } }
    },
    {
      "title": "24h PnL",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "targets": [{ "expr": "ratebridge_pnl_24h_usd", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0 } ] }
        }
      }
    },
    {
      "title": "Connected Exchanges",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "targets": [{ "expr": "ratebridge_connected_exchanges", "refId": "A" }],
      "fieldConfig": { "defaults": { "decimals": 0 } }
    },
    {
      "title": "Opportunities per Scan",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "ratebridge_opportunities_total",
          "legendFormat": "opportunities",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10 } } }
    },
    {
      "title": "Best Net % (top opportunity)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "ratebridge_best_net_pct",
          "legendFormat": "best net %",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 3 } }
    },
    {
      "title": "Exchange Balances",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "ratebridge_exchange_balance_usd",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "title": "Active Positions Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "ratebridge_active_positions",
          "legendFormat": "active",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 20 } } }
    },
    {
      "title": "24h Realized PnL",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "ratebridge_pnl_24h_usd",
          "legendFormat": "24h realized",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } }
    },
    {
      "title": "Cumulative Lifetime PnL",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "ratebridge_total_pnl_usd",
          "legendFormat": "lifetime",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } }
    }
  ]
}
