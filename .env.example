# Trinity Arbitrage Engine Configuration
# Copy to .env and fill with actual credentials

# Environment
ENVIRONMENT=production  # production, staging, development
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trinity_arbitrage
POSTGRES_USER=trinity
POSTGRES_PASSWORD=your_secure_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Exchange API Keys - Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# Exchange API Keys - Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# Exchange API Keys - OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=false

# Exchange API Keys - Bitget
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_TESTNET=false

# Risk Parameters
MAX_MARGIN_USAGE=0.30
MAX_POSITION_SIZE_USD=10000
MAX_ORPHAN_TIME_MS=500
MAX_HEDGE_GAP_MS=1000
MAX_WS_STALENESS_MS=500
DELTA_THRESHOLD=0.05

# Trading Parameters
MIN_NET_BPS=5.0
SLIPPAGE_BUFFER_BPS=2.0
SAFETY_BUFFER_BPS=3.0
BASIS_BUFFER_BPS=1.0
MAX_CHASE_ATTEMPTS=3
MAX_OPEN_TIME_MS=1200

# ── Telegram notifications + Mini App ───────────────────────────
# 1. Create a bot via @BotFather in Telegram → /newbot → copy the token here
# 2. Start a chat with your bot, send /start, then fetch the chat_id from
#    https://api.telegram.org/bot<TOKEN>/getUpdates  (look for chat.id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Event switches (default true — flip to false to mute)
TELEGRAM_NOTIFY_OPEN=true
TELEGRAM_NOTIFY_CLOSE=true
TELEGRAM_NOTIFY_SUMMARY=true
# Daily summary schedule (local time in TELEGRAM_SUMMARY_TZ)
TELEGRAM_SUMMARY_HOUR=23
TELEGRAM_SUMMARY_MINUTE=55
TELEGRAM_SUMMARY_TZ=Asia/Jerusalem
# Mini App: comma-separated whitelist of Telegram user IDs allowed to open
# the dashboard. Leave blank during first setup to allow any user whose
# initData validates, then restrict once you know your own Telegram ID.
TELEGRAM_ALLOWED_USER_IDS=
# Public HTTPS URL where the built dashboard is hosted. Used by /menu
# to launch the Mini App. Leave blank to disable the launcher (notifications
# still work).
TELEGRAM_MINI_APP_URL=

# ── Other monitoring ────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_PORT=9090

# Paper Trading Mode
PAPER_TRADING=true  # Set to false for live trading
DRY_RUN=true  # Additional safety flag
