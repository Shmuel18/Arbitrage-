# RateBridge — Environment Configuration
# Copy to .env and fill in credentials. Trading/risk params live in config.yaml, not here.
# Empty values = skip that exchange (bot will drop it cleanly at startup).

# ══ Core ═══════════════════════════════════════════════════════
ENVIRONMENT=production          # production | staging | development
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# ══ Redis (local Docker, bound to 127.0.0.1) ═══════════════════
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ══ Exchange API Credentials ═══════════════════════════════════
# Permissions required: Read + Trade. NEVER enable Withdraw.
# IP whitelist MUST include the server's public IP.

# Bitget
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_TESTNET=false

# Binance Futures (USDM)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=false

# KuCoin Futures
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=
KUCOIN_TESTNET=false

# Gate.io Futures
GATEIO_API_KEY=
GATEIO_API_SECRET=
GATEIO_TESTNET=false

# Kraken Futures
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_TESTNET=false

# ══ Telegram notifications + Mini App ══════════════════════════
# 1. @BotFather on Telegram → /newbot → copy token below
# 2. @userinfobot on Telegram → /start → copy your chat_id below
# 3. Send /start to your bot BEFORE launching RateBridge
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Which events trigger notifications (true/false)
TELEGRAM_NOTIFY_OPEN=true
TELEGRAM_NOTIFY_CLOSE=true
TELEGRAM_NOTIFY_SUMMARY=true

# Daily summary schedule (local time in TELEGRAM_SUMMARY_TZ)
TELEGRAM_SUMMARY_HOUR=23
TELEGRAM_SUMMARY_MINUTE=55
TELEGRAM_SUMMARY_TZ=Asia/Jerusalem

# Mini App: comma-separated whitelist of Telegram user IDs allowed
# to open the dashboard. Blank = allow anyone whose initData validates
# (OK during setup; restrict once you know your Telegram ID).
TELEGRAM_ALLOWED_USER_IDS=

# HTTPS URL where the built dashboard is hosted. Required for /menu
# Mini App launcher. Blank = Mini App disabled, notifications still work.
# MUST be HTTPS with a real domain (Telegram requirement).
TELEGRAM_MINI_APP_URL=

# ══ AI Assistant (any/all providers — auto-fallback on quota) ══════
# Natural-language Q&A in Telegram + dashboard chat. Set AT LEAST ONE;
# more = better (when one hits its quota, the next takes over).
#
#   GEMINI_API_KEY    — FREE, 1,500 req/day (gemini-2.0-flash)
#                       Get: https://aistudio.google.com/apikey
#
#   GROQ_API_KEY      — FREE, 14,400 req/day (llama-3.3-70b)
#                       Get: https://console.groq.com/keys
#
#   ANTHROPIC_API_KEY — Paid ~$0.01/question, best quality
#                       Get: https://console.anthropic.com/settings/keys
#
# AI_PROVIDER picks the primary; fallbacks run through the rest in order.
AI_PROVIDER=auto      # 'auto' | 'gemini' | 'groq' | 'anthropic'
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL=             # optional override (auto-picked per provider)
AI_MAX_TOKENS=1024
AI_LANG=auto          # 'auto' (detect Hebrew/English) | 'he' | 'en'

# ══ Trading Mode ═══════════════════════════════════════════════
# PAPER_TRADING=true  → connects to exchanges, simulates trades only
# DRY_RUN=true        → additional safety flag
# Flip both to false for LIVE trading with real money.
PAPER_TRADING=true
DRY_RUN=true
