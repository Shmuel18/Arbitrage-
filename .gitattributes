# Force LF on files that must run on Linux containers / VPS.
*.sh              text eol=lf
Dockerfile        text eol=lf
*.yml             text eol=lf
*.yaml            text eol=lf
*.conf            text eol=lf
*.template        text eol=lf
.dockerignore     text eol=lf
.env.*            text eol=lf
