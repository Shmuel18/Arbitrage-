# Trinity Arbitrage Engine — Production Environment
# Copy to .env on the server and fill in real values.
# NEVER commit the filled .env to git.

# ===== Deployment =====
ENVIRONMENT=production
LOG_LEVEL=INFO
DOMAIN=arbitrage.yourdomain.com
LETSENCRYPT_EMAIL=you@example.com

# ===== Redis (passwords required in production) =====
REDIS_HOST=redis
REDIS_PORT=6379
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_USE_OPENSSL_RAND
REDIS_DB=0

# ===== Postgres (only if you wire it up; not used by core bot) =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trinity_arbitrage
POSTGRES_USER=trinity
POSTGRES_PASSWORD=CHANGE_ME

# ===== Exchange API Keys =====
# IMPORTANT: Use API keys with FUTURES TRADING permission only.
# DISABLE withdrawal permission. Whitelist your VPS IP if the exchange supports it.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=false

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_TESTNET=false

# ===== Risk Parameters =====
MAX_MARGIN_USAGE=0.30
MAX_POSITION_SIZE_USD=10000
MAX_ORPHAN_TIME_MS=500
MAX_HEDGE_GAP_MS=1000
MAX_WS_STALENESS_MS=500
DELTA_THRESHOLD=0.05

# ===== Trading Parameters =====
MIN_NET_BPS=5.0
SLIPPAGE_BUFFER_BPS=2.0
SAFETY_BUFFER_BPS=3.0
BASIS_BUFFER_BPS=1.0
MAX_CHASE_ATTEMPTS=3
MAX_OPEN_TIME_MS=1200

# ===== Monitoring (optional but recommended) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SENTRY_DSN=
PROMETHEUS_PORT=9090

# ===== Trading Mode =====
# Start with PAPER_TRADING=true and DRY_RUN=true for 24-48h.
# Flip to false ONLY after the dashboard, alerts, and exchange connections are verified.
PAPER_TRADING=false
DRY_RUN=false
